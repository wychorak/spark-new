{
  "expo": {
    "name": "Spark",
    "slug": "sparknew",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon main.png",
    "scheme": "sparkconnect",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/photologo.png",
      "resizeMode": "contain",
      "backgroundColor": "#050507"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spark.cherryblossomconnect",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Spark uses your location to show approximate distance to nearby profiles."
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.spark.cherryblossomconnect",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon main.png",
        "backgroundColor": "#050507"
      },
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json"
    },
    "extra": {
      "eas": {
        "projectId": "replace-with-eas-project-id"
      }
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Spark uses your location to show approximate distance to nearby profiles."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Spark uses your selected photos to build your dating and friends profile."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "delayAppMeasurementInit": true,
          "optimizeInitialization": true,
          "optimizeAdLoading": true
        }
      ]
    ]
  }
}
