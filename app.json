{
  "expo": {
    "name": "Spark",
    "slug": "spark-cherry-blossom-connect",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sparkconnect",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fbfbfd"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spark.cherryblossomconnect",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.spark.cherryblossomconnect",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fbfbfd"
      },
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "eas": {
        "projectId": "replace-with-eas-project-id"
      }
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
