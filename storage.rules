rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/profile/{fileName} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || firestore.exists(/databases/(default)/documents/publicProfiles/$(uid)));
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType in ['image/jpeg', 'image/png', 'image/heic', 'image/heif', 'image/webp'];
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
