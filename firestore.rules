rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow create: if isOwner(uid);
      allow update, delete: if isOwner(uid);
      allow read: if signedIn() && (
        resource.data.privateProfile != true || isOwner(uid)
      );

      match /blocks/{blockedUid} {
        allow read, create, delete: if isOwner(uid);
        allow update: if false;
      }
    }


    match /accountDeletions/{uid} {
      allow create, update: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "requested";
      allow read, delete: if false;
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.targetUid is string
        && request.resource.data.reason is string;
      allow read, update, delete: if false;
    }

    match /matches/{matchId} {
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.memberUids;
      allow read, update: if signedIn()
        && request.auth.uid in resource.data.memberUids;
      allow delete: if false;
    }

    match /chatRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toProfileKey is string
        && request.resource.data.introMessage is string;
      allow read, update: if signedIn()
        && resource.data.fromUid == request.auth.uid;
      allow delete: if false;
    }

    match /messages/{threadId}/items/{messageId} {
      allow read, create: if signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/matches/$(threadId)).data.memberUids;
      allow update, delete: if false;
    }
  }
}
