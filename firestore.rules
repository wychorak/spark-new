rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function activeUser() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('moderationStatus', 'active') != 'suspended';
    }

    function isSparkOwner() {
      return signedIn()
        && request.auth.token.get('email_verified', false) == true
        && request.auth.token.get('email', '') == 'wychor234@gmail.com';
    }

    function isEventAdmin() {
      return isSparkOwner();
    }

    function allowedUserText(text) {
      return text is string
        && !text.lower().matches('.*(porn|porno|nudes?|onlyfans|escort|prostytucj|sekskamera|zgwalce|zabije cie|heil hitler).*');
    }

    function validIntentList(intents) {
      return intents is list
        && intents.size() >= 1 && intents.size() <= 3
        && intents[0] in ['Randki', 'Znajomi', 'LGBT+ / Społeczność']
        && (intents.size() < 2 || intents[1] in ['Randki', 'Znajomi', 'LGBT+ / Społeczność'])
        && (intents.size() < 3 || intents[2] in ['Randki', 'Znajomi', 'LGBT+ / Społeczność'])
        && (intents.size() < 2 || intents[0] != intents[1])
        && (intents.size() < 3 || (intents[0] != intents[2] && intents[1] != intents[2]));
    }

    function validIntentFields(data) {
      return (!('intents' in data) || validIntentList(data.intents))
        && (!('desiredIntents' in data) || validIntentList(data.desiredIntents));
    }

    function validGender(gender) {
      return gender in ['woman', 'man', 'nonbinary', 'unspecified'];
    }

    function validDesiredGenderList(genders) {
      return genders is list
        && genders.size() >= 1 && genders.size() <= 3
        && genders[0] in ['woman', 'man', 'nonbinary']
        && (genders.size() < 2 || genders[1] in ['woman', 'man', 'nonbinary'])
        && (genders.size() < 3 || genders[2] in ['woman', 'man', 'nonbinary'])
        && (genders.size() < 2 || genders[0] != genders[1])
        && (genders.size() < 3 || (genders[0] != genders[2] && genders[1] != genders[2]));
    }

    function validGenderPreferences(preferences) {
      return preferences is map
        && preferences.keys().hasOnly(['dating', 'friends', 'community'])
        && validDesiredGenderList(preferences.dating)
        && validDesiredGenderList(preferences.friends)
        && validDesiredGenderList(preferences.community);
    }

    function validGenderFields(data) {
      return (!('gender' in data) || validGender(data.gender))
        && (!('desiredGendersByIntent' in data) || validGenderPreferences(data.desiredGendersByIntent));
    }

    function hasRevenueCatPro() {
      return isSparkOwner() || (
        signedIn()
          && request.auth.token.get('activeEntitlements', []) is list
          && 'Sparknew Pro' in request.auth.token.get('activeEntitlements', [])
      );
    }

    function validPremiumUsageUpdate() {
      let previousPeriod = resource.data.get('superlikePeriod', 0);
      let previousUsed = resource.data.get('superlikesUsed', 0);
      let nextPeriod = request.resource.data.get('superlikePeriod', 0);
      let nextUsed = request.resource.data.get('superlikesUsed', 0);
      let currentPeriod = request.time.year() * 100 + request.time.month();
      return (nextPeriod == previousPeriod && nextUsed == previousUsed)
        || (
          hasRevenueCatPro()
          && nextPeriod == currentPeriod
          && nextUsed is int
          && nextUsed >= 1
          && nextUsed <= 10
          && (
            (previousPeriod == currentPeriod && nextUsed == previousUsed + 1)
            || (previousPeriod != currentPeriod && nextUsed == 1)
          )
        );
    }

    function validEventFields(event) {
      return event is map
        && event.id is string && event.id.size() >= 8 && event.id.size() <= 220
        && event.category in ['music', 'cinema', 'sport', 'games', 'city', 'travel']
        && event.name is string && event.name.size() >= 3 && event.name.size() <= 80
        && event.city is string && event.city.size() >= 2 && event.city.size() <= 80
        && event.date is string && event.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && event.kind == 'specific'
        && event.icon in [
          'microphone-variant', 'music-note', 'guitar-electric', 'movie-open-outline',
          'popcorn', 'stadium-outline', 'soccer', 'controller-classic-outline',
          'dice-multiple', 'city-variant-outline', 'palette-outline', 'airplane'
        ]
        && event.startsAt is string && event.startsAt.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*Z$')
        && event.endsAt is string && event.endsAt.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*Z$');
    }

    function validEvent(event) {
      return validEventFields(event)
        && event.keys().hasOnly(['id', 'category', 'name', 'city', 'date', 'kind', 'icon', 'startsAt', 'endsAt']);
    }

    function validSelectedEvent(event) {
      return validEvent(event)
        && exists(/databases/$(database)/documents/sparkEvents/$(event.id))
        && get(/databases/$(database)/documents/sparkEvents/$(event.id)).data.id == event.id
        && get(/databases/$(database)/documents/sparkEvents/$(event.id)).data.name == event.name
        && get(/databases/$(database)/documents/sparkEvents/$(event.id)).data.get('icon', event.icon) == event.icon
        && get(/databases/$(database)/documents/sparkEvents/$(event.id)).data.startsAt == event.startsAt
        && get(/databases/$(database)/documents/sparkEvents/$(event.id)).data.endsAt == event.endsAt;
    }

    function validEventList(events, eventIds) {
      return events is list && eventIds is list
        && events.size() == eventIds.size() && events.size() <= 4
        && (events.size() < 1 || (validSelectedEvent(events[0]) && eventIds[0] == events[0].id))
        && (events.size() < 2 || (validSelectedEvent(events[1]) && eventIds[1] == events[1].id))
        && (events.size() < 3 || (validSelectedEvent(events[2]) && eventIds[2] == events[2].id))
        && (events.size() < 4 || (validSelectedEvent(events[3]) && eventIds[3] == events[3].id));
    }

    function validMatch(data) {
      return data.keys().hasOnly(['memberUids', 'createdByUid', 'source', 'status', 'introMessage', 'eventContext', 'resetAt', 'createdAt', 'updatedAt', 'acceptedByUid', 'rejectedByUid', 'blockedByUid', 'unreadCountByUid', 'readAtByUid', 'lastMessageAt', 'lastMessageSenderUid', 'lastMessageText'])
        && data.memberUids is list && data.memberUids.size() == 2
        && data.memberUids[0] != data.memberUids[1]
        && data.createdByUid is string && data.createdByUid in data.memberUids
        && data.source in ['mutual-like', 'premium-request', 'superlike']
        && data.status in ['matched', 'requested', 'rejected', 'blocked']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (data.get('unreadCountByUid', null) == null || data.unreadCountByUid is map)
        && (data.get('readAtByUid', null) == null || data.readAtByUid is map)
        && (data.get('lastMessageAt', null) == null || data.lastMessageAt is timestamp)
        && (data.get('lastMessageSenderUid', null) == null || (data.lastMessageSenderUid is string && data.lastMessageSenderUid in data.memberUids))
        && (data.get('lastMessageText', null) == null || (data.lastMessageText is string && data.lastMessageText.size() <= 240 && allowedUserText(data.lastMessageText)))
        && (data.get('resetAt', null) == null || data.resetAt is timestamp)
        && (data.get('eventContext', null) == null || validEvent(data.eventContext))
        && (data.get('introMessage', null) == null || (data.introMessage is string && data.introMessage.size() <= 500 && allowedUserText(data.introMessage)));
    }

    function otherMember(data) {
      return data.memberUids[0] == request.auth.uid ? data.memberUids[1] : data.memberUids[0];
    }

    function hasLike(fromUid, toUid) {
      return exists(/databases/$(database)/documents/swipes/$(fromUid + '_' + toUid))
        && get(/databases/$(database)/documents/swipes/$(fromUid + '_' + toUid)).data.fromUid == fromUid
        && get(/databases/$(database)/documents/swipes/$(fromUid + '_' + toUid)).data.toProfileKey == toUid
        && get(/databases/$(database)/documents/swipes/$(fromUid + '_' + toUid)).data.status == 'liked';
    }

    function hasSuperlike(fromUid, toUid) {
      return exists(/databases/$(database)/documents/swipes/$(fromUid + '_' + toUid))
        && get(/databases/$(database)/documents/swipes/$(fromUid + '_' + toUid)).data.fromUid == fromUid
        && get(/databases/$(database)/documents/swipes/$(fromUid + '_' + toUid)).data.toProfileKey == toUid
        && get(/databases/$(database)/documents/swipes/$(fromUid + '_' + toUid)).data.direction == 'superlike'
        && get(/databases/$(database)/documents/swipes/$(fromUid + '_' + toUid)).data.status == 'liked';
    }

    function validMatchCreation(data, matchId) {
      let otherUid = otherMember(data);
      return request.auth.uid in data.memberUids
        && data.createdByUid == request.auth.uid
        && (matchId == request.auth.uid + '_' + otherUid || matchId == otherUid + '_' + request.auth.uid)
        && exists(/databases/$(database)/documents/publicProfiles/$(otherUid))
        && !exists(/databases/$(database)/documents/users/$(request.auth.uid)/blocks/$(otherUid))
        && !exists(/databases/$(database)/documents/users/$(otherUid)/blocks/$(request.auth.uid))
        && (
          data.get('eventContext', null) == null
          || (
            data.eventContext.id in get(/databases/$(database)/documents/publicProfiles/$(request.auth.uid)).data.get('activeEventIds', [])
            && (
              data.eventContext.id in get(/databases/$(database)/documents/publicProfiles/$(otherUid)).data.get('activeEventIds', [])
              || get(/databases/$(database)/documents/publicProfiles/$(otherUid)).data.get('isTestProfile', false) == true
            )
          )
        )
        && (
          (data.source == 'mutual-like' && data.status == 'matched' && hasLike(request.auth.uid, otherUid) && hasLike(otherUid, request.auth.uid)) ||
          (data.source == 'superlike' && data.status == 'matched' && hasSuperlike(request.auth.uid, otherUid))
        );
    }

    function validSwipe(data, swipeId) {
      return data.keys().hasOnly(['fromUid', 'toProfileKey', 'direction', 'status', 'matchScore', 'eventContext', 'resetAt', 'updatedAt', 'createdAt'])
        && data.fromUid == request.auth.uid
        && data.toProfileKey is string
        && data.toProfileKey != request.auth.uid
        && swipeId == request.auth.uid + '_' + data.toProfileKey
        && data.direction in ['pass', 'like', 'superlike']
        && data.status == (data.direction == 'pass' ? 'passed' : 'liked')
        && exists(/databases/$(database)/documents/publicProfiles/$(data.toProfileKey))
        && (
          data.get('eventContext', null) == null
          || (
            validEvent(data.eventContext)
            && data.eventContext.id in get(/databases/$(database)/documents/publicProfiles/$(request.auth.uid)).data.get('activeEventIds', [])
            && (
              data.eventContext.id in get(/databases/$(database)/documents/publicProfiles/$(data.toProfileKey)).data.get('activeEventIds', [])
              || get(/databases/$(database)/documents/publicProfiles/$(data.toProfileKey)).data.get('isTestProfile', false) == true
            )
          )
        )
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }


    function validReport(data) {
      return data.keys().hasOnly(['reporterUid', 'targetUid', 'reason', 'context', 'status', 'createdAt'])
        && data.reporterUid == request.auth.uid
        && data.targetUid is string
        && data.reason is string && data.reason.size() > 0 && data.reason.size() <= 200
        && data.context is string && data.context.size() <= 4000
        && data.status == 'open'
        && data.createdAt == request.time;
    }

    function validNotificationPreferences(data) {
      return data is map
        && data.keys().hasOnly([
          'messages', 'matches', 'requests', 'events', 'sound', 'quietHoursEnabled',
          'quietStart', 'quietEnd', 'timeZone'
        ])
        && data.messages is bool
        && data.matches is bool
        && data.requests is bool
        && data.events is bool
        && data.sound is bool
        && data.quietHoursEnabled is bool
        && data.quietStart is string && data.quietStart.size() == 5
        && data.quietEnd is string && data.quietEnd.size() == 5
        && data.timeZone is string && data.timeZone.size() > 0 && data.timeZone.size() <= 80;
    }
    function protectedProfileFieldsUnchanged() {
      return request.resource.data.get('isPro', false) == resource.data.get('isPro', false)
        && request.resource.data.get('premiumPlan', 'free') == resource.data.get('premiumPlan', 'free')
        && request.resource.data.get('profilePhotoLimit', 3) == resource.data.get('profilePhotoLimit', 3)
        && request.resource.data.get('proVisibilityBoost', 'standard') == resource.data.get('proVisibilityBoost', 'standard')
        && request.resource.data.get('canSeeIncomingLikes', false) == resource.data.get('canSeeIncomingLikes', false)
        && request.resource.data.get('canSendChatRequests', false) == resource.data.get('canSendChatRequests', false)
        && request.resource.data.get('isTestProfile', false) == resource.data.get('isTestProfile', false)
        && request.resource.data.get('likedYou', false) == resource.data.get('likedYou', false)
        && request.resource.data.get('moderationStatus', 'active') == resource.data.get('moderationStatus', 'active');
    }
    function validPublicProfile(data, uid) {
      return data.keys().hasOnly([
          'uid', 'firstName', 'lastName', 'profileNameMode', 'nickname', 'gender', 'intent', 'intents', 'desiredGendersByIntent', 'bio',
          'ageBand', 'age', 'desiredAgeMin', 'desiredAgeMax', 'interests', 'activeEvents', 'activeEventIds', 'photoUrls', 'mainPhotoUrl',
          'city', 'country', 'location', 'socials', 'isPro', 'isTestProfile', 'moderationStatus', 'createdAt', 'updatedAt'
        ])
        && data.uid == uid
        && data.profileNameMode in ['realName', 'nickname']
        && data.firstName is string && data.firstName.size() <= 80
        && data.lastName is string && data.lastName.size() <= 80
        && data.nickname is string && data.nickname.size() <= 80
        && validGenderFields(data)
        && data.intent is string && data.intent.size() <= 120
        && (!('intents' in data) || validIntentList(data.intents))
        && data.bio is string && data.bio.size() >= 20 && data.bio.size() <= 300
        && (
          (data.profileNameMode == 'nickname' && data.nickname.size() >= 2)
          || (data.profileNameMode == 'realName' && data.firstName.size() >= 2)
        )
        && data.ageBand == '18+'
        && data.age is number && data.age >= 18 && data.age <= 99
        && data.desiredAgeMin is number && data.desiredAgeMin >= 18 && data.desiredAgeMin <= 99
        && data.desiredAgeMax is number && data.desiredAgeMax >= data.desiredAgeMin && data.desiredAgeMax <= 99
        && data.interests is list && data.interests.size() >= 3 && data.interests.size() <= 15
        && validEventList(data.activeEvents, data.activeEventIds)
        && data.photoUrls is list && data.photoUrls.size() >= 1
        && data.photoUrls.size() <= (hasRevenueCatPro() ? 15 : 3)
        && (
          data.mainPhotoUrl == null
          || (data.mainPhotoUrl is string && data.mainPhotoUrl.size() <= 2048 && data.mainPhotoUrl in data.photoUrls)
        )
        && data.city is string && data.city.size() <= 120
        && data.country is string && data.country.size() <= 120
        && data.socials is map
        && data.socials.keys().hasOnly(['Instagram', 'TikTok', 'Facebook'])
        && (!('Instagram' in data.socials) || (data.socials.Instagram is string && data.socials.Instagram.size() > 0 && data.socials.Instagram.size() <= 40))
        && (!('TikTok' in data.socials) || (data.socials.TikTok is string && data.socials.TikTok.size() > 0 && data.socials.TikTok.size() <= 40))
        && (!('Facebook' in data.socials) || (data.socials.Facebook is string && data.socials.Facebook.size() > 0 && data.socials.Facebook.size() <= 40))
        && data.isPro is bool
        && data.isTestProfile is bool
        && data.moderationStatus in ['active', 'suspended']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (
          data.location == null
          || (
            data.location is map
            && data.location.keys().hasOnly(['latitude', 'longitude'])
            && data.location.latitude is number
            && data.location.longitude is number
            && data.location.latitude >= -90 && data.location.latitude <= 90
            && data.location.longitude >= -180 && data.location.longitude <= 180
          )
        );
    }

    function protectedPublicFieldsUnchanged() {
      return request.resource.data.isPro == hasRevenueCatPro()
        && request.resource.data.get('isTestProfile', false) == resource.data.get('isTestProfile', false)
        && request.resource.data.get('moderationStatus', 'active') == resource.data.get('moderationStatus', 'active')
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /users/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.get('isPro', false) == false
        && request.resource.data.get('isTestProfile', false) == false
        && request.resource.data.get('likedYou', false) == false
        && request.resource.data.get('moderationStatus', 'active') == 'active'
        && request.resource.data.get('superlikePeriod', 0) == 0
        && request.resource.data.get('superlikesUsed', 0) == 0
        && validIntentFields(request.resource.data)
        && validGenderFields(request.resource.data);
      allow update: if isOwner(uid)
        && request.resource.data.uid == uid
        && resource.data.uid == uid
        && protectedProfileFieldsUnchanged()
        && validPremiumUsageUpdate()
        && validIntentFields(request.resource.data)
        && validGenderFields(request.resource.data);
      allow delete: if isOwner(uid);
      allow read: if isOwner(uid);

      match /blocks/{blockedUid} {
        allow read, delete: if isOwner(uid);
        allow create: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['blockedUid', 'createdAt'])
          && request.resource.data.blockedUid == blockedUid
          && request.resource.data.createdAt == request.time;
        allow update: if false;
      }

      match /profileViews/{viewerUid} {
        allow read, delete: if isOwner(uid) && hasRevenueCatPro();
        allow create: if activeUser()
          && request.auth.uid == viewerUid
          && uid != viewerUid
          && request.resource.data.keys().hasOnly(['viewerUid', 'targetUid', 'viewCount', 'lastViewedAt'])
          && request.resource.data.viewerUid == viewerUid
          && request.resource.data.targetUid == uid
          && request.resource.data.viewCount == 1
          && request.resource.data.lastViewedAt == request.time;
        allow update: if activeUser()
          && request.auth.uid == viewerUid
          && uid != viewerUid
          && request.resource.data.keys().hasOnly(['viewerUid', 'targetUid', 'viewCount', 'lastViewedAt'])
          && request.resource.data.viewerUid == resource.data.viewerUid
          && request.resource.data.targetUid == resource.data.targetUid
          && request.resource.data.viewerUid == viewerUid
          && request.resource.data.targetUid == uid
          && request.resource.data.viewCount == resource.data.viewCount + 1
          && request.time > resource.data.lastViewedAt + duration.value(10, 'm')
          && request.resource.data.lastViewedAt == request.time;
      }

      match /devices/{deviceId} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['token', 'platform', 'enabled', 'notificationPreferences', 'updatedAt'])
          && request.resource.data.token is string
          && request.resource.data.token.size() >= 20
          && request.resource.data.token.size() <= 250
          && request.resource.data.platform in ['ios', 'android']
          && request.resource.data.enabled is bool
          && validNotificationPreferences(request.resource.data.notificationPreferences)
          && request.resource.data.updatedAt == request.time;
      }
      match /settings/notifications {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && request.resource.data.keys().hasOnly([
            'messages', 'matches', 'requests', 'events', 'sound', 'quietHoursEnabled',
            'quietStart', 'quietEnd', 'timeZone', 'updatedAt'
          ])
          && request.resource.data.messages is bool
          && request.resource.data.matches is bool
          && request.resource.data.requests is bool
          && request.resource.data.events is bool
          && request.resource.data.sound is bool
          && request.resource.data.quietHoursEnabled is bool
          && request.resource.data.quietStart is string && request.resource.data.quietStart.size() == 5
          && request.resource.data.quietEnd is string && request.resource.data.quietEnd.size() == 5
          && request.resource.data.timeZone is string && request.resource.data.timeZone.size() > 0 && request.resource.data.timeZone.size() <= 80
          && request.resource.data.updatedAt == request.time;
        allow delete: if false;
      }
    }
    match /publicProfiles/{uid} {
      allow read: if signedIn();
      allow create: if isOwner(uid)
        && validPublicProfile(request.resource.data, uid)
        && request.resource.data.isPro == hasRevenueCatPro()
        && request.resource.data.get('isTestProfile', false) == false
        && request.resource.data.get('moderationStatus', 'active') == 'active';
      allow update: if isOwner(uid)
        && validPublicProfile(request.resource.data, uid)
        && protectedPublicFieldsUnchanged();
      allow delete: if isOwner(uid);
    }

    match /sparkEvents/{eventId} {
      allow read: if activeUser();
      allow create: if isEventAdmin()
        && request.resource.data.keys().hasOnly([
          'id', 'category', 'name', 'city', 'date', 'kind', 'icon', 'startsAt', 'endsAt',
          'createdByUid', 'deleteAt', 'createdAt', 'updatedAt'
        ])
        && validEventFields(request.resource.data)
        && request.resource.data.id == eventId
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.deleteAt is timestamp
        && request.resource.data.deleteAt > request.time
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow delete: if isEventAdmin();
      allow update: if false;
    }

    match /privateProfiles/{uid} {
      allow read, create, update, delete: if isOwner(uid);
    }
    match /accountDeletions/{uid} {
      allow read, create, update, delete: if false;
    }

    match /revenuecat_customers/{uid} {
      allow read: if isOwner(uid);
      allow create, update, delete: if false;
    }

    match /revenuecat_events/{eventId} {
      allow read: if signedIn() && resource.data.app_user_id == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /reports/{reportId} {
      allow create: if signedIn() && validReport(request.resource.data);
      allow read, update, delete: if false;
    }

    match /swipes/{swipeId} {
      allow create, update: if activeUser() && validSwipe(request.resource.data, swipeId);
      allow get: if signedIn() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toProfileKey == request.auth.uid
      );
      allow list: if signedIn() && (
        resource.data.fromUid == request.auth.uid ||
        (resource.data.toProfileKey == request.auth.uid && hasRevenueCatPro())
      );
      allow delete: if signedIn() && (
        resource.data.fromUid == request.auth.uid || resource.data.toProfileKey == request.auth.uid
      );
    }
    match /matches/{matchId} {
      allow create: if activeUser()
        && validMatch(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.get('unreadCountByUid', null) == null
        && request.resource.data.get('readAtByUid', null) == null
        && request.resource.data.get('lastMessageAt', null) == null
        && request.resource.data.get('lastMessageSenderUid', null) == null
        && request.resource.data.get('lastMessageText', null) == null
        && validMatchCreation(request.resource.data, matchId);
      allow read: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow update: if signedIn()
        && request.auth.uid in resource.data.memberUids
        && validMatch(request.resource.data)
        && request.resource.data.memberUids == resource.data.memberUids
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.source == resource.data.source
        && request.resource.data.get('introMessage', null) == resource.data.get('introMessage', null)
        && request.resource.data.get('eventContext', null) == resource.data.get('eventContext', null)
        && request.resource.data.get('resetAt', null) == resource.data.get('resetAt', null)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.get('unreadCountByUid', null) == resource.data.get('unreadCountByUid', null)
        && request.resource.data.get('readAtByUid', null) == resource.data.get('readAtByUid', null)
        && request.resource.data.get('lastMessageAt', null) == resource.data.get('lastMessageAt', null)
        && request.resource.data.get('lastMessageSenderUid', null) == resource.data.get('lastMessageSenderUid', null)
        && request.resource.data.get('lastMessageText', null) == resource.data.get('lastMessageText', null)
        && request.resource.data.updatedAt == request.time
        && (
          (
            resource.data.status == 'requested'
            && (
              (
                request.resource.data.status == 'matched'
                && request.resource.data.acceptedByUid == request.auth.uid
                && (
                  request.auth.uid != resource.data.createdByUid
                  || (
                    (hasLike(request.auth.uid, otherMember(resource.data))
                      && hasLike(otherMember(resource.data), request.auth.uid))
                    || hasSuperlike(request.auth.uid, otherMember(resource.data))
                  )
                )
              )
              || (
                request.auth.uid != resource.data.createdByUid
                && request.resource.data.status == 'rejected'
                && request.resource.data.rejectedByUid == request.auth.uid
              )
            )
          )
          || (
            resource.data.status in ['requested', 'matched']
            && request.resource.data.status == 'blocked'
            && request.resource.data.blockedByUid == request.auth.uid
          )
        );
      allow delete: if false;
    }


    match /messages/{threadId}/items/{messageId} {
      allow read: if signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/matches/$(threadId)).data.memberUids;
      // Callable function enforces membership, moderation and rate limits
      // with trusted server time.
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
