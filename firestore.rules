rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function validMatch(data) {
      return data.keys().hasOnly(['memberUids', 'createdByUid', 'source', 'status', 'introMessage', 'resetAt', 'createdAt', 'updatedAt', 'acceptedByUid', 'rejectedByUid', 'blockedByUid'])
        && data.memberUids is list && data.memberUids.size() == 2
        && data.createdByUid is string && data.createdByUid in data.memberUids
        && data.source in ['mutual-like', 'premium-request']
        && data.status in ['matched', 'requested', 'rejected', 'blocked'];
    }

    function validMessage(data) {
      return data.keys().hasOnly(['senderUid', 'text', 'createdAt'])
        && data.senderUid == request.auth.uid
        && data.text is string && data.text.size() > 0 && data.text.size() <= 2000;
    }

    function validReport(data) {
      return data.keys().hasOnly(['reporterUid', 'targetUid', 'reason', 'context', 'status', 'createdAt'])
        && data.reporterUid == request.auth.uid
        && data.targetUid is string
        && data.reason is string && data.reason.size() > 0 && data.reason.size() <= 200
        && data.context is string && data.context.size() <= 4000
        && data.status == 'open';
    }

    function protectedProfileFieldsUnchanged() {
      return request.resource.data.get('isPro', false) == resource.data.get('isPro', false)
        && request.resource.data.get('premiumPlan', 'free') == resource.data.get('premiumPlan', 'free')
        && request.resource.data.get('profilePhotoLimit', 3) == resource.data.get('profilePhotoLimit', 3)
        && request.resource.data.get('proVisibilityBoost', 'standard') == resource.data.get('proVisibilityBoost', 'standard')
        && request.resource.data.get('canSeeIncomingLikes', false) == resource.data.get('canSeeIncomingLikes', false)
        && request.resource.data.get('canSendChatRequests', false) == resource.data.get('canSendChatRequests', false)
        && request.resource.data.get('isTestProfile', false) == resource.data.get('isTestProfile', false)
        && request.resource.data.get('likedYou', false) == resource.data.get('likedYou', false);
    }

    match /users/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.get('isPro', false) == false
        && request.resource.data.get('isTestProfile', false) == false
        && request.resource.data.get('likedYou', false) == false;
      allow update: if isOwner(uid)
        && request.resource.data.uid == uid
        && resource.data.uid == uid
        && protectedProfileFieldsUnchanged();
      allow delete: if isOwner(uid);
      allow read: if signedIn() && (
        resource.data.privateProfile != true || resource.data.isTestProfile == true || isOwner(uid)
      );

      match /blocks/{blockedUid} {
        allow read, delete: if isOwner(uid);
        allow create: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['blockedUid', 'createdAt'])
          && request.resource.data.blockedUid == blockedUid;
        allow update: if false;
      }
    }



    match /privateProfiles/{uid} {
      allow read, create, update, delete: if isOwner(uid);
    }
    match /accountDeletions/{uid} {
      allow create, update: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "requested"
        && request.resource.data.keys().hasOnly(["uid", "reason", "status", "requestedAt"]);
      allow read, delete: if false;
    }

    match /reports/{reportId} {
      allow create: if signedIn() && validReport(request.resource.data);
      allow read, update, delete: if false;
    }

    match /swipes/{swipeId} {
      allow create, update: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toProfileKey is string
        && request.resource.data.direction in ["pass", "like", "superlike"];
      allow read: if signedIn() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toProfileKey == request.auth.uid
      );
      allow delete: if signedIn() && (
        resource.data.fromUid == request.auth.uid || resource.data.toProfileKey == request.auth.uid
      );
    }
    match /matches/{matchId} {
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.createdByUid == request.auth.uid
        && validMatch(request.resource.data);
      allow read: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow update: if signedIn()
        && request.auth.uid in resource.data.memberUids
        && validMatch(request.resource.data)
        && request.resource.data.memberUids == resource.data.memberUids
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          (resource.data.status == 'requested' && request.auth.uid != resource.data.createdByUid && request.resource.data.status in ['matched', 'rejected']) ||
          (resource.data.status == 'requested' && request.resource.data.status == 'blocked') ||
          (resource.data.status == 'matched' && request.resource.data.status == 'blocked')
        );
      allow delete: if signedIn() && request.auth.uid in resource.data.memberUids;
    }


    match /messages/{threadId}/items/{messageId} {
      allow read: if signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/matches/$(threadId)).data.memberUids;
      allow create: if signedIn()
        && get(/databases/$(database)/documents/matches/$(threadId)).data.status == 'matched'
        && request.auth.uid in get(/databases/$(database)/documents/matches/$(threadId)).data.memberUids
        && validMessage(request.resource.data);
      allow update: if false;
      allow delete: if signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/matches/$(threadId)).data.memberUids;
    }
  }
}
